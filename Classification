import numpy as np
import pandas as pd

# This function uses the trained classifier from the previous step
def identify_gas(mq135_val, mq3_val):
    # 1. Feature Engineering (Same as training)
    log_135 = np.log10(mq135_val)
    log_3 = np.log10(mq3_val)

    # Using our calculated constants for Ethanol (e) and Acetone (a)
    est_eth = np.power(mq135_val / 1.0801, 1/-0.0616)
    est_ace = np.power(mq135_val / 1.3137, 1/-0.1267)

    # 2. Format for model
    test_sample = pd.DataFrame([[log_135, log_3, est_eth, est_ace]],
                               columns=['log_135', 'log_3', 'est_eth_135', 'est_ace_135'])

    # 3. Predict Type and Concentration
    gas_type = classifier.predict(test_sample)[0]
    concs = regressor.predict(test_sample)[0]

    print(f"--- SENSOR READINGS: MQ135={mq135_val}, MQ3={mq3_val} ---")
    print(f"STATUS: {gas_type}")

    if gas_type == "Pure Ethanol":
        print(f"RESULT: Pure Ethanol detected at {concs[0]:.2f} ppm")
    elif gas_type == "Pure Acetone":
        print(f"RESULT: Pure Acetone detected at {concs[1]:.2f} ppm")
    else:
        print(f"RESULT: Mixture detected (Eth: {concs[0]:.1f} ppm, Ace: {concs[1]:.1f} ppm)")
    print("-" * 50)

