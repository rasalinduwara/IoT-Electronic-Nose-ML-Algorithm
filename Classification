import numpy as np
import pandas as pd

def identify_gas_with_confidence(mq135_val, mq3_val):
    # 1. Engineering the physics-based features
    log_135 = np.log10(mq135_val)
    log_3 = np.log10(mq3_val)

    # Constants for our power-law estimators
    # C = (RsRo / a)^(1/b)
    est_eth = np.power(mq135_val / 1.0801, 1/-0.0616)
    est_ace = np.power(mq135_val / 1.3137, 1/-0.1267)

    # 2. Prepare sample for the model
    test_sample = pd.DataFrame([[log_135, log_3, est_eth, est_ace]],
                               columns=['log_135', 'log_3', 'est_eth_135', 'est_ace_135'])

    # 3. Get Classification and Probability
    gas_type = classifier.predict(test_sample)[0]
    probs = classifier.predict_proba(test_sample)[0]
    classes = classifier.classes_

    # Map probabilities to class names
    conf_dict = dict(zip(classes, probs))
    confidence = conf_dict[gas_type] * 100

    # 4. Get Concentration Prediction
    concs = regressor.predict(test_sample)[0]

    # 5. Output Report
    print(f"--- SENSOR ANALYSIS: MQ135={mq135_val:.4f}, MQ3={mq3_val:.4f} ---")
    print(f"DETECTED STATE: **{gas_type}**")
    print(f"CONFIDENCE:     {confidence:.1f}%")

    if gas_type == "Pure Ethanol":
        print(f"CONCENTRATION:  {concs[0]:.2f} ppm")
    elif gas_type == "Pure Acetone":
        print(f"CONCENTRATION:  {concs[1]:.2f} ppm")
    else:
        print(f"COMPOSITION:    Eth: {concs[0]:.1f} ppm, Ace: {concs[1]:.1f} ppm")

    # Show secondary possibilities if confidence is low
    if confidence < 80:
        print(f"NOTICE: Low confidence. Secondary possibility: {sorted(conf_dict.items(), key=lambda x: x[1])[-2][0]}")
    print("-" * 60)

# --- RUNNING TESTS ---
print("TESTING PURE ETHANOL (100ppm):")
identify_gas_with_confidence(0.8215, 0.8219)

print("\nTESTING PURE ACETONE (100ppm):")
identify_gas_with_confidence(0.7373, 0.8324)

print("\nTESTING UNKNOWN MIXTURE (75/25):")
identify_gas_with_confidence(0.5818, 0.6802)
