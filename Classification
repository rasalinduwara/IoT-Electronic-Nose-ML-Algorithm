import pandas as pd
import numpy as np
from sklearn.ensemble import RandomForestRegressor, RandomForestClassifier
from sklearn.multioutput import MultiOutputRegressor

# 1. Dataset (Pure data + Mixture data)
data = {
    'eth_ppm': [100, 75, 50, 25, 0, 0, 0, 0, 75, 50, 25],
    'ace_ppm': [0, 0, 0, 0, 100, 75, 50, 25, 25, 50, 75],
    'mq135': [0.8215, 0.8237, 0.8373, 0.8924, 0.7373, 0.7671, 0.7788, 0.8837, 0.5818, 0.6561, 0.6965],
    'mq3': [0.8219, 0.8504, 0.8490, 0.8993, 0.8324, 0.8578, 0.8541, 0.9029, 0.6802, 0.8053, 0.8408]
}
df = pd.DataFrame(data)

# 2. Physics Constants
params = {
    'mq135': {'eth': {'a': 1.0801, 'b': -0.0616}, 'ace': {'a': 1.3137, 'b': -0.1267}},
    'mq3':   {'eth': {'a': 1.0848, 'b': -0.0593}, 'ace': {'a': 1.0681, 'b': -0.0535}}
}

# 3. Feature Engineering: The Conductance Estimators
def get_est(val, a, b):
    return np.power(np.maximum(val / a, 1e-6), 1/b)

df['log_135'] = np.log10(df['mq135'])
df['log_3'] = np.log10(df['mq3'])
df['est_eth_135'] = get_est(df['mq135'], params['mq135']['eth']['a'], params['mq135']['eth']['b'])
df['est_ace_135'] = get_est(df['mq135'], params['mq135']['ace']['a'], params['mq135']['ace']['b'])

# Target categorization
df['type'] = df.apply(lambda r: 'Pure' if (r.eth_ppm==0 or r.ace_ppm==0) else 'Mixture', axis=1)

# 4. ML Models
X = df[['log_135', 'log_3', 'est_eth_135', 'est_ace_135']]
y_class = df['type']
y_reg = df[['eth_ppm', 'ace_ppm']]

classifier = RandomForestClassifier(n_estimators=100, random_state=42).fit(X, y_class)
regressor = MultiOutputRegressor(RandomForestRegressor(n_estimators=100, random_state=42)).fit(X, y_reg)

# 5. Testing a new sample
sample_mq135 = 0.6561 # Example 50/50 mix
sample_mq3 = 0.8053
X_new = pd.DataFrame([[np.log10(sample_mq135), np.log10(sample_mq3),
                       get_est(sample_mq135, 1.08, -0.06), get_est(sample_mq135, 1.31, -0.12)]], columns=X.columns)

print(f"Prediction: {classifier.predict(X_new)[0]}")
print(f"Concentrations: {regressor.predict(X_new)[0]}")

