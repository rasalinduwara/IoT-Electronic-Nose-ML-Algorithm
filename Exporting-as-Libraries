import m2cgen as m2c

# 1. Convert the Classification Model (Pure vs Mix)
code_classifier = m2c.export_to_c(classifier)
with open("gas_classifier.h", "w") as f:
    f.write(code_classifier)

# 2. Convert the Regression Models (Concentrations) individually
# MultiOutputRegressor applies the base estimator to each target independently.
# We can access these individual estimators via the .estimators_ attribute.

# For Ethanol concentration
regressor_eth = regressor.estimators_[0]
code_regressor_eth = m2c.export_to_c(regressor_eth)
with open("gas_regressor_ethanol.h", "w") as f:
    f.write(code_regressor_eth)

# For Acetone concentration
regressor_ace = regressor.estimators_[1]
code_regressor_ace = m2c.export_to_c(regressor_ace)
with open("gas_regressor_acetone.h", "w") as f:
    f.write(code_regressor_ace)

print("C++ header files generated: gas_classifier.h, gas_regressor_ethanol.h, and gas_regressor_acetone.h")
