from sklearn.metrics import r2_score, mean_absolute_error

def show_linear_regression_accuracy(df, params):
    print("\n" + "="*40)
    print("   LINEAR REGRESSION (LOG-LOG) ACCURACY")
    print("="*40)

    for sensor in ['mq135', 'mq3']:
        for gas in ['eth', 'ace']:
            # 1. Get Actual Log Values
            # Filtering the dataframe for pure gas rows only
            mask = (df[f'{gas}_ppm'] > 0) & (df[f'{"ace" if gas=="eth" else "eth"}_ppm'] == 0)
            actual_log_conc = np.log10(df.loc[mask, f'{gas}_ppm'])
            actual_log_ratio = np.log10(df.loc[mask, sensor])

            # 2. Get Predicted Log Values from the Regression parameters (a and b)
            # log(y) = log(a) + b * log(x)
            a = params[sensor][gas]['a']
            b = params[sensor][gas]['b']
            pred_log_ratio = np.log10(a) + b * actual_log_conc

            # 3. Calculate Metrics
            r2 = r2_score(actual_log_ratio, pred_log_ratio)
            mae_log = mean_absolute_error(actual_log_ratio, pred_log_ratio)

            # Convert log error back to a percentage for easier understanding
            # Error in log10(y) of 0.01 is roughly a 2.3% error in the original ratio
            approx_error_pct = (10**mae_log - 1) * 100

            print(f"[{sensor.upper()} - {gas.upper()}]")
            print(f"  R² Score:      {r2:.4f}")
            print(f"  Log-MAE:       {mae_log:.4f}")
            print(f"  Avg Deviation: ~{approx_error_pct:.2f}%")
            print("-" * 20)

# Call the function using your existing dataframe and parameters
show_linear_regression_accuracy(df, params)
